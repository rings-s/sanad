# ── Copy to .env and fill in values ──────────────────────────────────────────
# cp .env.example .env

# ── Django ────────────────────────────────────────────────────────────────────
DJANGO_SECRET_KEY=change-me-to-a-long-random-string-minimum-50-chars
ALLOWED_HOSTS=localhost,127.0.0.1
ENVIRONMENT=development

# ── Database ─────────────────────────────────────────────────────────────────
# Dev (SQLite): leave blank — manage.py uses SQLite by default
# Prod: full PostgreSQL DSN
DATABASE_URL=postgresql://sanad:CHANGE_ME_db_password@localhost:5432/sanad

POSTGRES_DB=sanad
POSTGRES_USER=sanad
POSTGRES_PASSWORD=CHANGE_ME_db_password

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── Authentication ────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
# Google Cloud Console must have:
#   Authorized JavaScript origins: http://localhost:5173
#   Authorized redirect URIs:      http://localhost:5173/auth/google/callback/
#
# Cookie security — set to True in production (requires HTTPS)
AUTH_COOKIE_SECURE=False

# ── Frontend URL ──────────────────────────────────────────────────────────────
# Used to build password-reset and email-verification links in emails.
FRONTEND_URL=http://localhost:5173

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:5173

# ── Frontend (SvelteKit / Vite) ───────────────────────────────────────────────
# Set in frontend/.env — exposed to the browser, so use the PUBLIC client id.
VITE_API_URL=http://localhost:8000
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# ── File Storage: AWS S3 (thumbnails & audio — videos go to YouTube) ──────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=us-east-1
AWS_S3_CUSTOM_DOMAIN=

# ── Email ─────────────────────────────────────────────────────────────────────
# Development: Google SMTP (Gmail App Password)
EMAIL_HOST_USER=yourname@gmail.com
EMAIL_HOST_PASSWORD=your-gmail-app-password
# Production: Amazon SES
AWS_SES_REGION_NAME=us-east-1
DEFAULT_FROM_EMAIL=noreply@sanad.app

# Sheikh team notification email (receives new Q&A submissions)
SHEIKH_NOTIFICATION_EMAIL=sheikh@sanad.app

# ── YouTube Data API v3 ───────────────────────────────────────────────────────
# Paste the full contents of your OAuth2 token.json here (single line, JSON).
# If blank, content managers must supply youtube_video_id manually.
# YouTube Data API key — used to auto-fetch title/description/duration when a
# content manager pastes a video URL. Optional; URL parsing works without it.
YOUTUBE_API_KEY=

# ── Monitoring ────────────────────────────────────────────────────────────────
SENTRY_DSN=
